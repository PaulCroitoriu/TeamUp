rules_version = '2';

service cloud.firestore {
  match /databases/teamup-db/documents {

    // ── Users ──
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth.uid == userId;
    }

    // ── Businesses ──
    match /businesses/{businessId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && get(/databases/teamup-db/documents/users/$(request.auth.uid)).data.businessId == businessId;
    }

    // ── Venues ──
    match /venues/{venueId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.businessId != null;
      allow update: if request.auth != null
        && get(/databases/teamup-db/documents/users/$(request.auth.uid)).data.businessId == resource.data.businessId;

      // ── Pitches (subcollection) ──
      match /pitches/{pitchId} {
        allow read: if true;
        allow create, update: if request.auth != null
          && get(/databases/teamup-db/documents/users/$(request.auth.uid)).data.businessId == get(/databases/teamup-db/documents/venues/$(venueId)).data.businessId;
      }
    }

    // ── Pitches (collectionGroup) ──
    // Required for the player Explore screen which queries pitches across
    // every venue via collectionGroup('pitches'). Path-scoped rules above
    // do not authorise collectionGroup queries — this wildcard does.
    match /{path=**}/pitches/{pitchId} {
      allow read: if true;
    }

    // ── Games ──
    match /games/{gameId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    // ── Bookings ──
    // Status updates (confirm/cancel) come from either the booker or the
    // owning business's user. Both are authenticated; we just check that
    // the caller is one of the parties on the booking.
    match /bookings/{bookingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && (
          request.auth.uid == resource.data.bookerId
          || get(/databases/teamup-db/documents/users/$(request.auth.uid)).data.businessId == resource.data.businessId
        );
    }

    // ── Notifications ──
    // Recipient-targeted documents. Any authenticated user can create a
    // notification (e.g. booker writes to business owner on createBooking,
    // business writes to booker on confirm/cancel). Only the recipient may
    // read or mark them read.
    match /notifications/{notificationId} {
      allow read: if request.auth != null
        && request.auth.uid == resource.data.recipientId;
      allow create: if request.auth != null
        && request.resource.data.recipientId is string;
      allow update: if request.auth != null
        && request.auth.uid == resource.data.recipientId;
    }

    // ── Conversations ──
    match /conversations/{conversationId} {
      // `resource == null` allows reading a non-existent doc (the
      // transactional get() in MessagingService.sendBookingMessage hits
      // this on the first message of a booking).
      allow get: if request.auth != null
        && (resource == null
            || request.auth.uid in resource.data.participantIds);
      allow list: if request.auth != null
        && request.auth.uid in resource.data.participantIds;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participantIds;
      // Updates (lastMessage, lastMessageAt) come from any participant.
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participantIds;

      match /messages/{messageId} {
        // Membership is mirrored on each message doc, so no cross-doc
        // lookup is needed (avoids `getAfter` edge cases when the parent
        // conversation is being created in the same transaction).
        allow read: if request.auth != null
          && request.auth.uid in resource.data.participantIds;
        allow create: if request.auth != null
          && request.auth.uid in request.resource.data.participantIds
          && request.resource.data.senderId == request.auth.uid;
      }
    }
  }
}
